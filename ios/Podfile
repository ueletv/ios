platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run flutter pub get first."
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# SVGAPlayer 2.5.x 在 Xcode 16+ 的 OSAtomic API 已不可用，用 stdatomic 兼容实现替换
def patch_svga_pbobjc!(installer)
  pbobjc = File.join(installer.sandbox.root, 'SVGAPlayer', 'Source', 'pbobjc', 'Svga.pbobjc.m')
  return unless File.exist?(pbobjc)

  contents = File.read(pbobjc)
  marker = '// Xcode16 SVGA atomic compatibility v2'
  return if contents.include?(marker)

  # 移除旧版补丁或仅加 import 的补丁
  contents.gsub!(/^#import <libkern\/OSAtomic\.h>\n/, '')
  contents.gsub!(
    /\/\/ Xcode16 SVGA atomic compatibility.*?\n#define OSAtomicCompareAndSwapPtrBarrier.*?\n/m,
    ''
  )

  header = <<~'PATCH'

    // Xcode16 SVGA atomic compatibility v2
    #import <stdatomic.h>
    static inline BOOL SVGA_OSAtomicCompareAndSwapPtrBarrier(
        void *oldp, void *newp, void *volatile *theValue) {
      atomic_uintptr_t *obj = (atomic_uintptr_t *)theValue;
      uintptr_t expected = (uintptr_t)oldp;
      uintptr_t desired = (uintptr_t)newp;
      return atomic_compare_exchange_strong_explicit(
          obj, &expected, desired, memory_order_acq_rel, memory_order_relaxed);
    }
    #undef OSAtomicCompareAndSwapPtrBarrier
    #define OSAtomicCompareAndSwapPtrBarrier(a, b, c) \
        SVGA_OSAtomicCompareAndSwapPtrBarrier((a), (b), (c))

  PATCH

  anchor = '#pragma mark - SVGAProtoSvgaRoot'
  if contents.include?(anchor)
    contents = contents.sub(anchor, "#{header}\n#{anchor}")
  else
    contents = "#{header}\n#{contents}"
  end

  File.write(pbobjc, contents)
  puts 'Patched SVGAPlayer Svga.pbobjc.m for Xcode 16 (stdatomic)'
end

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  # 直播间礼物 SVGA（对齐 Android SVGAPlayer）
  pod 'SVGAPlayer', '~> 2.5.7'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
      config.build_settings['DEAD_CODE_STRIPPING'] = 'YES'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['SWIFT_STRICT_CONCURRENCY'] = 'minimal'
    end
  end
  patch_svga_pbobjc!(installer)
end
